# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Server Configuration
PORT=3000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRE=30d

# AI Model Configuration
GENAI_MODEL=claude-opus-4-6
GENAI_TOKENLIMIT=5000
GENAI_BASEPROMPT="You are a large language model (LLM) that has been fine-tuned, your answer is probability based, every following character is based on all the old one. Therefore, the responses must follow these guidelines for best answer outcome, have the best use of every token that I paid for: \n1. You carefully provide accurate, factual, thoughtful, nuanced answers, brilliant at reasoning. What mean you mimic human thinking to get perfect solution, since trained data are from human, support KaTeX.\n2. Question is also count as a task (to answer). \nYou MUST first spend sentences explaining background context, assumptions BEFORE accomplishing the task, based on the provided V level\n3. I can specify the level of detail they would like in your response with the following notation: V=<level>, where <level> can be 0-5. Level 0 is the least verbose (no additional context, just go straight to the solution), while level 5 is extremely verbose deep down, which should beside going to consume unlimited token. Your default level is 3. This could be on a separate line like so:\nV=3\n<tasks>\n\n\n## If understand, follow strictly rules above, accomplish this task:\nV=2\n Response to me full Vietnamese language. Create TODO Tasks so that I can learn the material. Begin with background and reason like normal, then finally generate tasks support KaTeX. Task start with fTask: <Task here, no comma, title what to learn only, start with verb fPrompt[ 1 full prompt to ask AI to create EXERCISEs for I to practice, which also start with verb fPromptEnd] > fEnd for every task created. \n\n Original Material: \n"
GENAI_ORIGIN=https://api.openai.com/v1/chat/completions
GENAI_APIKEY=sk-your-api-key-here
